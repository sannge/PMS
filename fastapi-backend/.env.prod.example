# ══════════════════════════════════════════════════════════════
# PROD environment — same VMs, production DB/buckets/indexes
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in passwords

# Database — production database
DB_SERVER=10.18.137.202
DB_NAME=pmsdb
DB_USER=pmsdbuser
DB_PASSWORD=<your-db-password>
DB_PORT=5432
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100

# Redis — DB 0 (dev uses DB 1)
REDIS_URL=redis://:<your-redis-password>@10.18.137.202:6379/0
REDIS_MAX_CONNECTIONS=200
REDIS_SOCKET_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_REQUIRED=true

# MinIO — production buckets
MINIO_ENDPOINT=10.18.137.108:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<your-minio-password>
MINIO_SECURE=false
MINIO_ATTACHMENTS_BUCKET=pm-attachments
MINIO_IMAGES_BUCKET=pm-images

# MeiliSearch — production index
MEILISEARCH_URL=http://10.18.137.108:7700
MEILISEARCH_API_KEY=<your-meili-key>
MEILISEARCH_INDEX_NAME=documents
MEILISEARCH_TIMEOUT=5.0

# Auth
JWT_SECRET=<your-jwt-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=14
JWT_REFRESH_SECRET=<your-refresh-secret>

# Server
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8001

# WebSocket
WS_MAX_CONNECTIONS_PER_USER=50
WS_MAX_MESSAGE_SIZE=65536

# AI
AI_ENCRYPTION_KEY=<your-encryption-key>
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_EMBEDDING_DIMENSIONS=1536

# OAuth
OPENAI_OAUTH_CLIENT_ID=
ANTHROPIC_OAUTH_CLIENT_ID=
OAUTH_STATE_TTL_SECONDS=600

# SMTP
SMTP_HOST=10.16.32.51
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=none
SMTP_FROM_EMAIL=FTX-ROBOT@foxconn.com
SMTP_FROM_NAME=PM Desktop
SMTP_TIMEOUT=60
SMTP_VALIDATE_CERTS=false
SMTP_ENABLED=false

# Email Verification
EMAIL_VERIFICATION_CODE_EXPIRY_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_CODE_EXPIRY_MINUTES=15

# ARQ Worker Schedule
ARQ_ARCHIVE_HOURS=0,12
ARQ_ARCHIVE_MINUTES=
ARQ_PRESENCE_CLEANUP_SECONDS=0,30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8001

# Test Database
TEST_DB_USER=pmsdbuser
TEST_DB_PASSWORD=<your-db-password>

# Debug
SQL_ECHO=false
